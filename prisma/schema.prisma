generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
  APPLICATION_OWNER
}

enum EmployeeStatus {
  PENDING
  ACTIVE
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED        // Legacy: kept for existing data
  NEEDS_REVISION  // Replaces REJECTED for new send-backs
}

model Employee {
  id          String         @id @default(cuid())
  clerkUserId String?        @unique
  name        String
  email       String         @unique
  homeAddress String?
  role        Role           @default(EMPLOYEE)
  status      EmployeeStatus @default(ACTIVE)
  isActive    Boolean        @default(true)

  // Approver relationships (replaces single managerId)
  approvers     EmployeeApprover[] @relation("EmployeeApprovers")   // people who can approve MY reports
  canApproveFor EmployeeApprover[] @relation("ApproverEmployees")   // employees whose reports I can approve

  expenseReports  ExpenseReport[] @relation("EmployeeReports")
  approvedReports ExpenseReport[] @relation("ApproverReports")
  rejectedReports ExpenseReport[] @relation("RejectorReports")
  deletedReports  ExpenseReport[] @relation("DeleterReports")
  approvedTrips   Trip[]          @relation("TripApprover")
  rejectedTrips   Trip[]          @relation("TripRejector")
  favoriteTrips   FavoriteTrip[]
  mileageRates    MileageRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeApprover {
  id         String   @id @default(cuid())
  employeeId String
  approverId String
  employee   Employee @relation("EmployeeApprovers", fields: [employeeId], references: [id])
  approver   Employee @relation("ApproverEmployees", fields: [approverId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([employeeId, approverId])
  @@index([employeeId])
  @@index([approverId])
}

model MileageRate {
  id            String   @id @default(cuid())
  rate          Float
  effectiveDate DateTime
  createdById   String
  createdBy     Employee @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())

  @@index([effectiveDate])
}

model Property {
  id       String  @id @default(cuid())
  name     String  @unique
  address  String
  city     String?
  state    String?
  isActive Boolean @default(true)

  originTrips           Trip[]         @relation("OriginProperty")
  destinationTrips      Trip[]         @relation("DestinationProperty")
  favoriteOrigins       FavoriteTrip[] @relation("FavOriginProperty")
  favoriteDestinations  FavoriteTrip[] @relation("FavDestinationProperty")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FavoriteTrip {
  id                    String  @id @default(cuid())
  employeeId            String
  name                  String
  originType            String
  originPropertyId      String?
  originAddress         String?
  destinationType       String
  destinationPropertyId String?
  destinationAddress    String?
  roundTrip             Boolean @default(false)

  employee            Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  originProperty      Property? @relation("FavOriginProperty", fields: [originPropertyId], references: [id])
  destinationProperty Property? @relation("FavDestinationProperty", fields: [destinationPropertyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
}

model ExpenseReport {
  id              String       @id @default(cuid())
  reportNumber    String       @unique
  employeeId      String
  status          ReportStatus @default(DRAFT)
  periodMonth     Int
  periodYear      Int
  totalMiles      Float        @default(0)
  totalAmount     Float        @default(0)
  mileageRate     Float        @default(0.70)
  notes           String?
  resubmitMessage String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  approvedById    String?
  rejectedById    String?
  parentReportId  String?
  deletedAt       DateTime?
  deletedById     String?
  deletionReason  String?

  employee      Employee  @relation("EmployeeReports", fields: [employeeId], references: [id])
  approvedBy    Employee? @relation("ApproverReports", fields: [approvedById], references: [id])
  rejectedBy    Employee? @relation("RejectorReports", fields: [rejectedById], references: [id])
  deletedBy     Employee? @relation("DeleterReports", fields: [deletedById], references: [id])
  parentReport  ExpenseReport?  @relation("ReportResubmissions", fields: [parentReportId], references: [id])
  resubmissions ExpenseReport[] @relation("ReportResubmissions")

  trips             Trip[]
  accountingExports AccountingExportLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, periodYear, periodMonth])
  @@index([status])
}

model AccountingExportLog {
  id              String        @id @default(cuid())
  sentAt          DateTime      @default(now())
  fileName        String
  sentToEmail     String
  tripCount       Int
  totalMiles      Float
  totalAmount     Float
  employeeName    String
  managerName     String
  reportNumber    String
  expenseReportId String
  expenseReport   ExpenseReport @relation(fields: [expenseReportId], references: [id])

  createdAt DateTime @default(now())
}

model Trip {
  id                    String   @id @default(cuid())
  reportId              String
  date                  DateTime
  originType            String
  originPropertyId      String?
  originAddress         String?
  destinationType       String
  destinationPropertyId String?
  destinationAddress    String?
  roundTrip             Boolean  @default(false)
  distance              Float    @default(0)
  purpose               String?
  tripStatus            String   @default("PENDING")
  tripRejectionReason   String?
  managerNote           String?
  tripApprovedById      String?
  tripRejectedById      String?

  report              ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  originProperty      Property?     @relation("OriginProperty", fields: [originPropertyId], references: [id])
  destinationProperty Property?     @relation("DestinationProperty", fields: [destinationPropertyId], references: [id])
  tripApprovedBy      Employee?     @relation("TripApprover", fields: [tripApprovedById], references: [id])
  tripRejectedBy      Employee?     @relation("TripRejector", fields: [tripRejectedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
}
